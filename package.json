{
  "name": "@popscode/click-builder",
  "version": "1.0.0",
  "description": "Build click-track lyric videos from YAML song definitions and source video.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "fixtures:video-sync": "node --loader ts-node/esm src/testing/video-fixture-generator.cli.ts",
    "test:bdd": "node scripts/bdd-runner.mjs",
    "prepack": "npm run build"
  },
  "config": {
    "real": "",
    "mock": "",
    "muxsync": "",
    "tags": ""
  },
  "main": "dist/pipeline.js",
  "types": "dist/pipeline.d.ts",
  "bin": {
    "click-builder": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sgillbee/click-builder.git"
  },
  "bugs": {
    "url": "https://github.com/sgillbee/click-builder/issues"
  },
  "homepage": "https://github.com/sgillbee/click-builder#readme",
  "keywords": [
    "cli",
    "ffmpeg",
    "video",
    "audio",
    "click-track",
    "metronome",
    "lyrics",
    "worship"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "directories": {
    "doc": "docs"
  },
  "dependencies": {
    "@fission-ai/openspec": "^1.4.1",
    "fluent-ffmpeg": "^2.1.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@types/cucumber": "^6.0.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
